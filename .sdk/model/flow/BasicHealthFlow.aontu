# BasicHealthFlow

main: kit: flow: BasicHealthFlow:
{
  entity: "health",
  kind: "basic",
  name: "BasicHealthFlow",
  step: [
    {
      input: {
        ref: "health_ref01",
        srcdatavar: "health_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-health_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicHealthFlow"
}